{
  "$schema": "https://opencode.ai/config.json",
  // OpenCode-Go Power Pack — standard tier config (Windows form). Generated by install.ps1. For macOS/Linux, the installer rewrites mcp.*.command arrays from ["cmd","/c","npx",...] to ["npx",...].
  "username": "operator",
  "model": "opencode-go/glm-5.2",
  "small_model": "opencode-go/deepseek-v4-flash",
  "default_agent": "build",
  "enabled_providers": ["opencode-go"],
  "instructions": ["AGENTS.md"],
  "snapshot": true,
  "autoupdate": "notify",
  "share": "disabled",

  "provider": {
    "opencode-go": {
      "options": {
        "setCacheKey": false,
        "timeout": false,
        "headerTimeout": 60000,
        "chunkTimeout": 120000
      }
    }
  },

  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 10000
  },

  "permission": {
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "edit": "allow",
    "todowrite": "allow",
    "question": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "lsp": "allow",
    "skill": "allow",
    "task": "allow",
    "external_directory": { "*": "allow" },
    "bash": {
      "rm -rf / *": "deny",
      "rm -rf ~ *": "deny",
      "rm -rf ~/* *": "deny",
      "rm -rf C:\\ *": "deny",
      "rm -rf /Users *": "deny",
      "rm -rf /home *": "deny",
      "git push --force *": "deny",
      "git push -f *": "deny",
      "git push --force-with-lease *": "allow",
      "sudo rm *": "deny",
      "mkfs*": "deny",
      "dd if=* of=/dev/*": "deny",
      ":(){ :|:& };:*": "deny",
      "chmod -R 777 / *": "deny",
      "*": "allow"
    }
  },

  // Main agent definitions live in agents/*.md files (description, mode, steps, color, permission, prompt). This section only pins models for the toggle-models script and defines trivial hidden agents inline.
  "agent": {
    "build":             { "model": "opencode-go/glm-5.2" },
    "plan":              { "model": "opencode-go/deepseek-v4-pro" },
    "reviewer":          { "model": "opencode-go/qwen3.7-max" },
    "explorer":          { "model": "opencode-go/deepseek-v4-flash" },
    "data-engineer":     { "model": "opencode-go/kimi-k2.7-code" },
    "frontend-engineer": { "model": "opencode-go/glm-5.2" },
    "devops-engineer":   { "model": "opencode-go/deepseek-v4-pro" },
    "doc-writer":        { "model": "opencode-go/mimo-v2.5" },
    "title":             { "description": "Generates session titles.", "mode": "subagent", "model": "opencode-go/deepseek-v4-flash", "hidden": true },
    "summary":           { "description": "Generates session summaries.", "mode": "subagent", "model": "opencode-go/deepseek-v4-flash", "hidden": true },
    "compaction":        { "description": "Compacts context when context window fills.", "mode": "subagent", "model": "opencode-go/deepseek-v4-flash", "hidden": true }
  },

  // Slash command definitions live in commands/*.md files. This section is intentionally empty.
  "command": {},

  "mcp": {
    "playwright": {
      "type": "local",
      "command": ["cmd", "/c", "npx", "-y", "@playwright/mcp@latest"],
      "enabled": true,
      "timeout": 30000
    },
    "github": {
      "type": "local",
      "command": ["cmd", "/c", "npx", "-y", "@modelcontextprotocol/server-github"],
      "enabled": true,
      "timeout": 15000,
      "environment": {
        "GITHUB_TOKEN": "{env:GITHUB_TOKEN}"
      }
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true,
      "timeout": 15000
    },
    "sequential-thinking": {
      "type": "local",
      "command": ["cmd", "/c", "npx", "-y", "@modelcontextprotocol/server-sequential-thinking"],
      "enabled": true,
      "timeout": 15000
    },
    "fetch": {
      "type": "local",
      "command": ["cmd", "/c", "uvx", "mcp-server-fetch"],
      "enabled": true,
      "timeout": 30000
    },
    "filesystem": {
      "type": "local",
      "command": ["cmd", "/c", "npx", "-y", "@modelcontextprotocol/server-filesystem", "."],
      "enabled": true,
      "timeout": 10000
    },
    "memory": {
      "type": "local",
      "command": ["cmd", "/c", "npx", "-y", "@modelcontextprotocol/server-memory"],
      "enabled": true,
      "timeout": 10000
    },
    "time": {
      "type": "local",
      "command": ["cmd", "/c", "uvx", "mcp-server-time"],
      "enabled": true,
      "timeout": 10000
    },
    "git-utils": {
      "type": "local",
      "command": ["cmd", "/c", "uvx", "mcp-server-git"],
      "enabled": true,
      "timeout": 10000
    },
    "repomix": {
      "type": "local",
      "command": ["cmd", "/c", "npx", "-y", "repomix@latest", "--mcp"],
      "enabled": true,
      "timeout": 30000
    },
    "code-review-graph": {
      "type": "local",
      "command": ["cmd", "/c", "code-review-graph", "serve"],
      "enabled": true,
      "timeout": 30000
    },
    "pakt": {
      "type": "local",
      "command": ["cmd", "/c", "npx", "-y", "@sriinnu/pakt", "serve", "--stdio"],
      "enabled": true,
      "timeout": 15000
    }
  },

  "plugin": [
    "superpowers@git+https://github.com/obra/superpowers.git"
  ],

  "tool_output": {
    "max_lines": 2000,
    "max_bytes": 51200
  },

  "experimental": {
    "primary_tools": ["edit"],
    "mcp_timeout": 30000,
    "continue_loop_on_deny": true
  }
}
